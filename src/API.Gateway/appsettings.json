{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",

      // Silences the "VisualStudioCredential.GetToken succeeded" Service Bus noise ---
      "Azure.Identity": "Warning",
      "Azure.Core": "Warning",
      "Azure.Messaging.ServiceBus": "Warning",

      // Silences the "Execution attempt... '-standard//Standard-Retry'" noise ---
      "Polly": "Warning",
      "Microsoft.Extensions.Http.Resilience": "Warning",
      "System.Net.Http.HttpClient": "Warning",

      // Silences the SQL Database noise (from the previous step) ---
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Npgsql": "Warning"
    }
  },
  "Console": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Error",
      "Microsoft.Extensions.Diagnostics.HealthChecks": "None"
    }
  },
  "EventBus": {
    "SubscriptionClientName": "APIGateway"
  },
  "AllowedHosts": "*",
  "Basemaps": {
    "PublicBaseUrl": ""
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "ForwardedHeaders": {
    "AllowedHosts": [],
    "KnownProxies": [],
    "KnownNetworks": [],
    "AllowUnknownProxies": false
  }
}
